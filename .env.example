# Web env is defined in apps/web/.env.local (see apps/web/.env.local.example)

# -------------------------------------------------------------------
# Core runtime (oracle + backend jobs)
# -------------------------------------------------------------------
APP_READ_DATABASE_URL=postgresql://app_read:<password>@127.0.0.1:5432/valcore-sepolia-testnet
APP_WRITE_DATABASE_URL=postgresql://app_write:<password>@127.0.0.1:5432/valcore-sepolia-testnet
DB_SSL_REJECT_UNAUTHORIZED=false

ORACLE_VALCORE_CHAIN_ENABLED=true

ORACLE_PORT=3101
ORACLE_TRUST_PROXY=false
ORACLE_CORS_ORIGINS=http://localhost:3000
ORACLE_ADMIN_API_KEY=
ORACLE_STRATEGIST_API_KEY=
ORACLE_RATE_LIMIT_ERROR_INGEST_MAX=180

# -------------------------------------------------------------------
# Chain runtime (single-chain, strict)
# -------------------------------------------------------------------
CHAIN_KEY=sepolia_testnet
CHAIN_LABEL=Ethereum Sepolia
CHAIN_TYPE=evm
CHAIN_ID=11155111
CHAIN_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_RPC_FALLBACK_URLS=
CHAIN_EXPLORER_URL=https://sepolia.etherscan.io
CHAIN_NATIVE_SYMBOL=ETH
CHAIN_NATIVE_TOKEN_ADDRESS=

VALCORE_ADDRESS=
STABLECOIN_ADDRESS=
STABLECOIN_SYMBOL=USDT
STABLECOIN_NAME=Mock Tether
STABLECOIN_DECIMALS=18
TREASURY_ADDRESS=
DEPLOY_MOCK_STABLECOIN=true

ORACLE_PRIVATE_KEY=
CONTRACT_ADMIN_PRIVATE_KEY=
PAUSER_PRIVATE_KEY=
FAUCET_MINTER_PRIVATE_KEY=
AUDITOR_PRIVATE_KEY=
AUDITOR_ADDRESS=
DEPLOYER_PRIVATE_KEY=
TREASURY_PRIVATE_KEY=
ORACLE_ACCOUNT_ADDRESS=
CONTRACT_ADMIN_ACCOUNT_ADDRESS=
PAUSER_ACCOUNT_ADDRESS=
FAUCET_MINTER_ACCOUNT_ADDRESS=
AUDITOR_ACCOUNT_ADDRESS=
DEPLOYER_ACCOUNT_ADDRESS=

# Gameplay / timing
DRAFT_OPEN_HOURS=23
AUTOMATION_MODE=REACTIVE
AUTOMATION_TICK_MS=15000
AUTOMATION_REACTIVE_AUTO_AUDIT=true
REACTIVE_STALL_GRACE_SECONDS=120
REACTIVE_CHAIN_RPC_URL=https://lasna-rpc.rnk.dev
REACTIVE_CHAIN_ID=5318007
REACTIVE_EXECUTOR_PRIVATE_KEY=
REACTIVE_DISPATCHER_ADDRESS=
REACTIVE_RECEIVER_ADDRESS=
REACTIVE_CALLBACK_PROXY_ADDRESS=0xc9f36411C9897e7F959D99ffca2a0Ba7ee0D7bDA
REACTIVE_CALLBACK_SENDER_ADDRESS=
REACTIVE_CALLBACK_GAS_LIMIT=900000
REACTIVE_DESTINATION_WAIT_MS=240000
REACTIVE_DESTINATION_POLL_MS=3000
REACTIVE_EXPLORER_URL=https://lasna.reactscan.net
WEEK_DURATION_DAYS=6
COOLDOWN_HOURS=1
PRINCIPAL_RATIO_BPS=8000
PROTOCOL_FEE_BPS=1000
MIN_DEPOSIT_STABLECOIN=50
FAUCET_STABLECOIN_AMOUNT=200
FAUCET_COOLDOWN_HOURS=24

# Price providers
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
REDSTONE_PRICES_URL=https://api.redstone.finance/prices
REDSTONE_PROVIDER=redstone
REDSTONE_REQUEST_TIMEOUT_MS=8000

# Tx policy (defaults shown)
CHAIN_TX_RETRY_BASE_MS=1500
CHAIN_TX_MAX_ATTEMPTS=4
CHAIN_TX_FEE_BUMP_BPS=1500
CHAIN_TX_GAS_LIMIT_BUFFER_BPS=2000
CHAIN_TX_CONFIRMATIONS=1

# Job retry / self-heal (defaults shown)
JOB_RETRY_BASE_MS=5000
JOB_RETRY_MAX_MS=60000
JOB_RETRY_JITTER_MS=1500
JOB_RETRY_MAX_ATTEMPTS=0
SELF_HEAL_POLL_MS=5000
SELF_HEAL_BATCH_SIZE=5
SELF_HEAL_BASE_MS=4000
SELF_HEAL_MAX_MS=120000
SELF_HEAL_JITTER_MS=1200
SELF_HEAL_DEFAULT_MAX_ATTEMPTS=12
MOCK_SCORE_SNAPSHOT_INTERVAL_MS=600000
START_WEEK_MOCK_LINEUP_COUNT=100

# Optional:
# RUN_WEEK_BASE_TIME_MS=
# JOB_WEBHOOK_URL=
# JOB_WEBHOOK_API_KEY=

# Error alerts (webhook/Telegram ready)
ERROR_ALERTS_ENABLED=false
ERROR_ALERT_WINDOW_MINUTES=5
ERROR_ALERT_THRESHOLD=20
ERROR_ALERT_MIN_SEVERITY=error
ERROR_ALERT_COOLDOWN_MINUTES=15
ERROR_ALERT_WEBHOOK_URL=
ERROR_ALERT_WEBHOOK_API_KEY=
ERROR_ALERT_TELEGRAM_BOT_TOKEN=
ERROR_ALERT_TELEGRAM_CHAT_ID=

# Optional script helpers
# CLAIMANT_PRIVATE_KEY=
# USER_PRIVATE_KEY=
# ORACLE_URL=http://localhost:3101
# MOCK_DEPOSIT=1000
# FAUCET_TO=
# FAUCET_AMOUNT=10000

# -------------------------------------------------------------------
# Local Cloud SQL proxy automation (scripts/dev-start.ps1)
# -------------------------------------------------------------------
CLOUD_SQL_PROXY_ENABLED=true
CLOUD_SQL_INSTANCE_CONNECTION_NAME=project:region:instance
CLOUD_SQL_PROXY_ADDRESS=127.0.0.1
CLOUD_SQL_PROXY_PORT=5432
CLOUD_SQL_PROXY_PRIVATE_IP=false
CLOUD_SQL_PROXY_USE_GCLOUD_AUTH=true
